{
	"id": "ranobe-gemini-library",
	"name": "Ranobe Gemini Library",
	"short_name": "RG Library",
	"description": "Your Novel Library powered by Ranobe Gemini — track, enhance, and organise your web novels with AI.",
	"version": "5.0.0",
	"start_url": "library.html?standalone=1",
	"scope": "./",
	"display": "standalone",
