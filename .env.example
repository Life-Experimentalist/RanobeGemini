# Build-time secret injection template for Ranobe Gemini
# Copy this file to .env and fill only values you need for local/private builds.
# Source files remain secret-free; values are injected into dist build output.

# Google Drive OAuth (optional)
RG_DRIVE_CLIENT_ID=
RG_DRIVE_CLIENT_SECRET=

# Optional telemetry endpoint (opt-in telemetry only)
RG_TELEMETRY_ENDPOINT=
